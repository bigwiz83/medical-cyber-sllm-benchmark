{
  "$defs": {
    "FocusDimension": {
      "enum": [
        "asset_inventory",
        "cve_applicability",
        "evidence_grounding",
        "exposure_prerequisites",
        "configuration_controls",
        "attack_path_consistency",
        "clinical_workflow_context",
        "false_positive_control"
      ],
      "title": "FocusDimension",
      "type": "string"
    },
    "PlannedRole": {
      "additionalProperties": false,
      "description": "Host-canonicalized specialist role.",
      "properties": {
        "depends_on": {
          "default": [],
          "items": {
            "maxLength": 6,
            "minLength": 6,
            "pattern": "^role_[123]$",
            "type": "string"
          },
          "maxItems": 2,
          "title": "Depends On",
          "type": "array"
        },
        "focus_dimensions": {
          "items": {"$ref": "#/$defs/FocusDimension"},
          "maxItems": 3,
          "minItems": 1,
          "title": "Focus Dimensions",
          "type": "array"
        },
        "objective": {
          "maxLength": 512,
          "minLength": 3,
          "title": "Objective",
          "type": "string"
        },
        "ordinal": {
          "maximum": 3,
          "minimum": 1,
          "title": "Ordinal",
          "type": "integer"
        },
        "role_id": {
          "maxLength": 6,
          "minLength": 6,
          "pattern": "^role_[123]$",
          "title": "Role Id",
          "type": "string"
        },
        "title": {
          "maxLength": 512,
          "minLength": 3,
          "title": "Title",
          "type": "string"
        }
      },
      "required": ["ordinal", "role_id", "title", "objective", "focus_dimensions"],
      "title": "PlannedRole",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Host-canonicalized plan used by specialist and synthesis calls.",
  "properties": {
    "roles": {
      "maxItems": 3,
      "minItems": 3,
      "prefixItems": [
        {"$ref": "#/$defs/PlannedRole"},
        {"$ref": "#/$defs/PlannedRole"},
        {"$ref": "#/$defs/PlannedRole"}
      ],
      "title": "Roles",
      "type": "array"
    },
    "schema_version": {
      "const": "qwen-autonomous-canonical-plan-2.0.0",
      "default": "qwen-autonomous-canonical-plan-2.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {"const": "ok", "default": "ok", "title": "Status", "type": "string"},
    "synthesis_strategy": {
      "maxLength": 512,
      "minLength": 3,
      "title": "Synthesis Strategy",
      "type": "string"
    }
  },
  "required": ["roles", "synthesis_strategy"],
  "title": "OrchestrationPlan",
  "type": "object"
}
